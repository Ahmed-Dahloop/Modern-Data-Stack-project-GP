    where ((upper(sch.nspname) = upper('stg') and
           upper(tbl.relname) = upper('stg_products')) or (upper(sch.nspname) = upper('public') and
           upper(tbl.relname) = upper('ods_orders')) or (upper(sch.nspname) = upper('public') and
