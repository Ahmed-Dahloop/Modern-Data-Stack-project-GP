[0m12:18:29.927319 [debug] [Thread-3 (]: On model.olist_dbt.fact_orders: /* {"app": "dbt", "dbt_version": "1.11.11", "profile_name": "olist_dbt", "target_name": "dev", "node_id": "model.olist_dbt.fact_orders"} */

  create view "olist_db"."stg"."fact_orders__dbt_tmp"
    
    
  as (
    with orders as (
    select * from "olist_db"."stg"."stg_orders"
),

items as (
    select
        order_id,
        product_id,
        seller_id,

        count(*) as total_items,
        sum(price) as total_price,
        sum(freight_value) as total_freight
    from "olist_db"."stg"."stg_order_items"
    group by order_id, product_id, seller_id
),

payments as (
    select 
        order_id,
        sum(payment_value) as total_payment
    from "olist_db"."stg"."stg_order_payments"
    group by order_id
),

reviews as (
    select 
        order_id,
        avg(review_score) as avg_review_score
    from "olist_db"."stg"."stg_order_reviews"
    group by order_id
)

select
    -- 🔑 KEYS (FACT LEVEL)
    o.order_id,
    o.customer_id,
    i.product_id,
    i.seller_id,

    -- 📦 ORDER ATTRIBUTES
    o.order_status,
    o.order_purchase_timestamp,
    o.order_approved_at,
    o.order_delivered_customer_date,
    o.order_estimated_delivery_date,

    -- 💰 MEASURES
    coalesce(p.total_payment, 0) as total_payment,
    coalesce(i.total_items, 0) as total_items,
    coalesce(i.total_price, 0) as total_price,
    coalesce(i.total_freight, 0) as total_freight,
    coalesce(r.avg_review_score, 0) as avg_review_score,

    -- 🚩 FLAGS
    case when o.order_approved_at is not null then 1 else 0 end as is_approved,
    case when o.order_delivered_customer_date is not null then 1 else 0 end as is_delivered

from orders o
left join items i on o.order_id = i.order_id
left join payments p on o.order_id = p.order_id
left join reviews r on o.order_id = r.order_id
  );
